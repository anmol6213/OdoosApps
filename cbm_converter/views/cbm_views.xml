<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sale Order Line -->
    <record id="view_sale_order_line_pieces" model="ir.ui.view">
        <field name="name">sale.order.line.pieces</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="/form/sheet/notebook/page[@name='order_lines']/field[@name='order_line']/list//field[@name='product_uom_qty']" position="after">
                <field name="x_studio_pieces_1" string="Pcs" optional="show"
                       column_invisible="parent.company_id not in [3, 4, 5, 6]"/>
            </xpath>
        </field>
    </record>

    <!-- Invoice Line -->
    <record id="view_invoice_line_pieces" model="ir.ui.view">
        <field name="name">account.move.line.pieces</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='quantity']" position="after">
                <field name="x_studio_pieces_1" string="Pcs" optional="show"
                       column_invisible="parent.company_id not in [3, 4, 5, 6]"/>
            </xpath>
        </field>
    </record>

    <!-- Delivery -->
    <record id="view_stock_move_line_pieces" model="ir.ui.view">
        <field name="name">stock.move.line.pieces</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='quantity'][@readonly='not is_quantity_done_editable']" position="after">
                <field name="x_studio_pieces_1" string="Pcs" optional="show"
                       column_invisible="parent.company_id not in [3, 4, 5, 6]"/>
            </xpath>
        </field>
    </record>

    <!-- Return Picking - company_id नाही line मध्ये -->
    <record id="view_stock_return_picking_line_pieces" model="ir.ui.view">
        <field name="name">stock.return.picking.line.pieces</field>
        <field name="model">stock.return.picking</field>
        <field name="inherit_id" ref="stock.view_stock_return_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_return_moves']//field[@name='quantity']" position="after">
                <field name="x_studio_pieces_1" string="Pcs" optional="show"
                       column_invisible="True"/>
            </xpath>
        </field>
    </record>

</odoo>
