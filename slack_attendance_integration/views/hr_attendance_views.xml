<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Attendance form view with break tracking -->
   <record id="view_attendance_form_breaks" model="ir.ui.view">
    <field name="name">hr.attendance.form.breaks</field>
    <field name="model">hr.attendance</field>
    <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
    <field name="arch" type="xml">
        <!-- Add fields after worked_hours -->
        <xpath expr="//field[@name='worked_hours']" position="after">
            <field name="total_break_duration" widget="float_time"/>
            <field name="net_worked_hours" widget="float_time"/>
            <field name="slack_created" invisible="1"/>
        </xpath>
        <!-- Add breaks notebook page -->
        <xpath expr="//sheet" position="inside">
            <notebook>
                <page string="Breaks" name="breaks">
                   <field name="break_ids" context="{'default_employee_id': employee_id, 'default_attendance_id': id}">
    <list editable="bottom">
                            <field name="break_start"/>
                            <field name="break_end"/>
                            <field name="duration" widget="float_time"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </xpath>
    </field>
</record>
>

    <!-- Extend Attendance tree view -->
    <record id="view_attendance_tree_breaks" model="ir.ui.view">
        <field name="name">hr.attendance.tree.breaks</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='worked_hours']" position="after">
                <field name="total_break_duration" widget="float_time" optional="show"/>
                <field name="net_worked_hours" widget="float_time" optional="show"/>
                <field name="slack_created" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_attendance_pivot_breaks" model="ir.ui.view">
        <field name="name">hr.attendance.pivot.breaks</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expected_hours']" position="after">
                 <field name="total_break_duration" type="measure" widget="float_time"/>
                <field name="net_worked_hours" type="measure" widget="float_time"/>
            </xpath>
        </field>
    </record>


