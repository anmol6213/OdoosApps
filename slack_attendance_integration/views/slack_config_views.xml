<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Slack Configuration Form View -->
    <record id="view_slack_config_form" model="ir.ui.view">
        <field name="name">slack.config.form</field>
        <field name="model">slack.config</field>
        <field name="arch" type="xml">
            <form string="Slack Configuration">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="min_working_hours"/>
                            <field name="send_daily_summary"/>
                            <field name="summary_time" invisible="not send_daily_summary"/>
                        </group>
                    </group>

                    <!-- ✅ NEW: Attendance Rules Section -->
                    <group string="Attendance Rules">
                        <group>
                            <field name="login_grace_minutes"
                                   help="Login time will be shown as (actual time - this value). E.g. Login at 10:00 → shows 9:55"/>
                        </group>
                        <group>
                            <field name="min_break_minutes"
                                   help="Breaks shorter than this will NOT be counted. E.g. 5 min break with limit 5 → ignored"/>
                        </group>
                    </group>

                    <group string="Slack Credentials">
                        <group>
                            <field name="signing_secret" password="True"/>
                            <field name="webhook_url"/>
                        </group>
                        <group>
                            <field name="bot_token" password="True"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <div class="alert alert-info" role="alert">
                                <h4>Setup Instructions:</h4>
                                <ol>
                                    <li>Go to <a href="https://api.slack.com/apps" target="_blank">api.slack.com/apps</a></li>
                                    <li>Create a new app or select existing</li>
                                    <li>Under "Basic Information", copy the <strong>Signing Secret</strong></li>
                                    <li>Under "OAuth &amp; Permissions", copy the <strong>Bot User OAuth Token</strong></li>
                                    <li>Under "Slash Commands", create commands:
                                        <ul>
                                            <li>/login - Request URL: https://your-domain.com/slack/attendance</li>
                                            <li>/logout - Request URL: https://your-domain.com/slack/attendance</li>
                                            <li>/break - Request URL: https://your-domain.com/slack/attendance</li>
                                            <li>/resume - Request URL: https://your-domain.com/slack/attendance</li>
                                        </ul>
                                    </li>
                                </ol>
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Slack Configuration Tree View -->
    <record id="view_slack_config_tree" model="ir.ui.view">
        <field name="name">slack.config.tree</field>
        <field name="model">slack.config</field>
        <field name="arch" type="xml">
            <list string="Slack Configurations">
                <field name="name"/>
                <field name="active"/>
                <field name="min_working_hours"/>
                <field name="login_grace_minutes"/>
                <field name="min_break_minutes"/>
                <field name="send_daily_summary"/>
            </list>
        </field>
    </record>

    <!-- Slack Configuration Action -->
    <record id="action_slack_config" model="ir.actions.act_window">
        <field name="name">Slack Configuration</field>
        <field name="res_model">slack.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure your Slack integration
            </p>
            <p>
                Set up Slack credentials and attendance settings here.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_slack_config"
              name="Slack Configuration"
              parent="hr_attendance.menu_hr_attendance_root"
              action="action_slack_config"
              sequence="100"/>

</odoo>
