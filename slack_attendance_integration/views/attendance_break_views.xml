<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Attendance Break Form View -->
    <record id="view_attendance_break_form" model="ir.ui.view">
        <field name="name">attendance.break.form</field>
        <field name="model">attendance.break</field>
        <field name="arch" type="xml">
            <form string="Attendance Break">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="attendance_id"/>
                        </group>
                        <group>
                            <field name="break_start"/>
                            <field name="break_end"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Attendance Break Tree View -->
    <record id="view_attendance_break_tree" model="ir.ui.view">
        <field name="name">attendance.break.tree</field>
        <field name="model">attendance.break</field>
        <field name="arch" type="xml">
            <list string="Attendance Breaks">
                <field name="employee_id"/>
                <field name="attendance_id"/>
                <field name="break_start"/>
                <field name="break_end"/>
                <field name="duration" widget="float_time"/>
            </list>
        </field>
    </record>

    <!-- Attendance Break Action -->
    <record id="action_attendance_break" model="ir.actions.act_window">
        <field name="name">Attendance Breaks</field>
        <field name="res_model">attendance.break</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No breaks recorded yet
            </p>
            <p>
                Employee breaks will appear here.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_attendance_break"
              name="Breaks"
              parent="hr_attendance.menu_hr_attendance_root"
              action="action_attendance_break"
              sequence="20"/>
</odoo>