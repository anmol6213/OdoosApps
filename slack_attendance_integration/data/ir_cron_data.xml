<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Daily AI Attendance Summary Cron -->
        <record id="ir_cron_send_ai_daily_summary" model="ir.cron">
            <field name="name">Slack: Send AI Daily Attendance Summary</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="state">code</field>
            <field name="code">model.action_send_ai_daily_summary()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=18, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

    </data>
</odoo>
